---
const navItems = [
  { text: "works", href: "/project/home" },
  { text: "kind words", href: "/kind-words" },
  // { text: "resume", href: "/system/style-guide" },
];
---

<div
  class="sidebar relative flex-none overflow-hidden px-8 lg:pointer-events-none lg:fixed lg:inset-0 lg:z-40 lg:flex lg:px-0"
>
  <script is:inline>
    const sidebar = document.querySelector(".sidebar");
    if (window.location.pathname !== "/" && window.innerWidth <= 768) {
      sidebar.classList.add("sidebar-hidden");
    }
  </script>
  <div
    class="flex w-full bg-neutral-50 lg:pointer-events-auto lg:mr-[calc(max(2rem,50%-38rem)+39.7rem)] lg:min-w-[32rem] lg:overflow-y-auto lg:overflow-x-hidden lg:pl-[max(4rem,calc(50%-38rem))]"
  >
    <div
      class="mx-auto max-w-lg lg:mx-0 lg:flex lg:w-96 lg:max-w-none lg:flex-col"
    >
      <div class="pb-16 pt-20 sm:pb-20 sm:pt-32 lg:py-20">
        <!-- <p class="text-kotei-800">Hi there,<br /> My name is</p> -->
        <a href="/">
          <h1
            class="font-display text-5xl md:text-8xl font-medium text-kotei-800 hover:text-kotei-1050"
          >
            Emerson Kirby.
          </h1>
        </a>
        <p class="mt-4 text-sm text-kotei-600">
        Research driven product builder
        </p>
        <p class="mt-2 text-sm text-neutral-500">
        I build products spanning signal processing, digital health, software, and connected hardware. I can discuss 
        experimental design with your researcher team, implementation details with engineers, and product strategy with founders.
        </p>
        <p class="mt-2 text-sm text-neutral-500">
        I combine analytical thinking with creative problem solving, but at the end of the day, my goal is singular: build proven & effective products.
        </p>
      
        <p class="mt-2 mb-8 text-sm text-neutral-500">
          You can reach me by
          <button
            class="copy text-kotei-600 transition-all hover:text-kotei-1050"
            >email</button
          >
          and on
          <a
            href="https://www.linkedin.com/in/emerson-kirby-94124b222/"
            class="text-kotei-600 transition-all hover:text-kotei-1050"
            >LinkedIn</a
          > &
          <a
            href="https://github.com/emersonk"
            class="text-kotei-600 transition-all hover:text-kotei-1050"
            >GitHub.</a
          >
        </p>
        <script>
          const buttons = document.querySelectorAll("button.copy");
          buttons.forEach((button) => {
            const htmlButton = button as HTMLButtonElement;
            htmlButton.addEventListener("click", () => {
              const email = "em@emersonkirby.com";
              navigator.clipboard
                .writeText(email)
                .then(() => {
                  htmlButton.innerText = "copied!";
                  setTimeout(() => {
                    htmlButton.innerText = "email";
                  }, 2000); // Reset after 2 seconds
                })
                .catch((err) => {
                  console.error("Failed to copy: ", err);
                });
            });
          });
        </script>

        {
          navItems.map((item) => (
            <a
              class="flex items-center font-semibold text-kotei-600 transition-all hover:text-kotei-1050"
              href={item.href}
            >
              {item.text} &nbsp; &rarr;
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
