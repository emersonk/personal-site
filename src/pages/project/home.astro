---
import { getCollection } from "astro:content";
const allProjects = (await getCollection("projects")).sort((a, b) =>
  a.slug.localeCompare(b.slug),
);
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectPreviews from "../../components/project/ProjectPreviewCard.astro";
---

<BaseLayout>
  <section class="bg-neutral-100">
    <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8 py-20">
      <div class="lg:ml-96 lg:flex lg:w-full lg:justify-end lg:pl-32">
        <div class="mx-auto max-w-lg lg:mx-0 lg:w-0 lg:max-w-xl lg:flex-auto">
          <h1 class="font-display text-5xl font-medium text-kotei-800">
            Selected projects
          </h1>
          <div class="grid grid-cols-1 lg:grid-cols-1 mt-12 gap-20">
            {
              allProjects.map((project) => (
                <ProjectPreviews
                  url={"/project/" + project.slug}
                  slug={project.slug}
                  description={project.data.technicalDescription}
                  name={project.data.client}
                  thumbnail={project.data.thumbnail.url}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
