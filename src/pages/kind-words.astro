---
import BaseLayout from "@/layouts/BaseLayout.astro";

const testimonials = [
  {
    excerpt:
      "His expertise was super valuable with his out the box thinking and resourcefulness accelerating our technical progress.",
    quote:
      "We had the pleasure working with Emerson on developing a medical device for incontinence management. Emerson brought both a strong technical and business lens to the development process. As a small start up, his expertise was super valuable with his out the box thinking and resourcefulness accelerating our technical progress. He was also a highly trusted source in helping us hire and lead technical staff. Would love the opportunity to work with Emerson again. Highly recommended.",
    name: "Martina Viduka",
    role: "CEO",
    organization: "Advosense",
  },
  {
    excerpt:
      "Emerson has a unique balance of technical expertise with the ability to communicate in a non-technical way.",
    quote:
      "Emerson is highly collaborative, detail-oriented, and is always looking to enhance the user experience. He's an exceptional problem-solver and continually worked to optimize Lightheart's functionality and aesthetic. Emerson has a unique balance of technical expertise with the ability to communicate in a non-technical way. This allowed Emerson to translate our validated physiological data into code which significantly increased Lightheart's accuracy.",
    name: "Sean Locke, PhD",
    role: "Associate Professor",
    organization: "Brock University",
  },
];

const gobsmackedMentions = [
  {
    quote:
      "very cool idea, interesting take on how to reformat instructions so they're actually useful.",
    name: "signal",
  },
  {
    quote: "I write my recipe cards grouped like this as well. Beautiful!",
    name: "rebent",
  },
  {
    quote:
      "Really neat tool! I've always grouped ingredients vertically and instructions horizontally, so I love how your tool automates this and makes it aesthetically pleasing.",
    name: "kris-kay",
  },
  {
    quote: "Love the name. The idea is intriguing. I can think of formatting some of my recipes for other people.",
    name: "doctornemo",
  },
  {
    quote: "This couldn't be more opaque to me.",
    name: "tiny frying pan"
  },
    {
    quote: "my gob remains unsmacked.",
    name: "Greg_Ace"
  }
];
---

<BaseLayout>
  <section class="bg-neutral-100">
    <div class="mx-auto max-w-7xl px-6 py-20 lg:flex lg:px-8">
      <div class="lg:ml-96 lg:flex lg:w-full lg:justify-end lg:pl-32">
        <div class="mx-auto max-w-lg lg:mx-0 lg:w-0 lg:max-w-xl lg:flex-auto">
          <!-- <p class="text-sm uppercase tracking-[0.2em] text-kotei-600">
            Kind words
          </p> -->
          <h1 class="font-display text-5xl font-medium text-kotei-800">
            Kind words
          </h1>
          <p class="mt-4 max-w-2xl text-sm text-neutral-500">
            Notes from clients, partners, and users
          </p>

          <div class="mt-12 space-y-8">
            {
              testimonials.map((testimonial) => (
                <article
                  x-data="{ open: false, excerptHeight: 0, fullHeight: 0 }"
                  x-init="$nextTick(() => { excerptHeight = $refs.excerptMeasure.getBoundingClientRect().height; fullHeight = $refs.fullMeasure.getBoundingClientRect().height; })"
                  class="group relative rounded-3xl border border-neutral-200 bg-neutral-50 shadow-[0_24px_60px_-34px_rgba(45,75,101,0.2)] transition duration-200 ease-out hover:-translate-y-1 hover:shadow-[0_28px_70px_-32px_rgba(45,75,101,0.35)]"
                >
                  <button
                    type="button"
                    class="block w-full p-8 text-left"
                    @click="open = !open; $nextTick(() => { excerptHeight = $refs.excerptMeasure.getBoundingClientRect().height; fullHeight = $refs.fullMeasure.getBoundingClientRect().height; })"
                    :aria-expanded="open.toString()"
                  >
                    <div
                      class="relative overflow-hidden transition-[height] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"
                      :style="`height: ${open ? fullHeight : excerptHeight}px`"
                    >
                      <p
                        class="absolute inset-0 font-display text-2xl leading-relaxed text-kotei-800 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"
                        :class="open ? 'pointer-events-none -translate-y-3 opacity-0 scale-[0.985]' : 'translate-y-0 opacity-100 scale-100'"
                      >
                        "{testimonial.excerpt}"
                      </p>
                      <p
                        class="absolute inset-0 font-display text-xl leading-relaxed text-kotei-800 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"
                        :class="open ? 'translate-y-0 opacity-100 scale-100 delay-75' : 'pointer-events-none translate-y-3 opacity-0 scale-[0.985]'"
                      >
                        "{testimonial.quote}"
                      </p>
                    </div>

                    <div class="mt-6 flex items-center justify-between gap-4 border-t border-neutral-200 pt-5">
                      <div>
                        <p class="text-lg font-semibold text-kotei-800">
                          {testimonial.name}
                        </p>
                        <p class="text-sm text-neutral-500">
                          {testimonial.role}
                          {" · "}
                          {testimonial.organization}
                        </p>
                      </div>
                      <span
                        class="text-xs font-semibold uppercase tracking-[0.18em] text-kotei-600 transition-transform duration-300"
                        :class="open ? 'translate-y-0' : 'translate-y-0'"
                        x-text="open ? 'Show less' : 'Read more'"
                      ></span>
                    </div>
                  </button>

                  <div class="pointer-events-none absolute inset-x-8 top-8 -z-10 overflow-hidden opacity-0">
                    <p
                      x-ref="excerptMeasure"
                      class="font-display text-2xl leading-relaxed text-kotei-800"
                    >
                      "{testimonial.excerpt}"
                    </p>
                    <p
                      x-ref="fullMeasure"
                      class="font-display text-xl leading-relaxed text-kotei-800"
                    >
                      "{testimonial.quote}"
                    </p>
                  </div>
                </article>
              ))
            }
          </div>

          <section class="mt-16 rounded-3xl border border-dashed border-kotei-300 bg-kotei-50/40 p-8">
            <p class="text-sm uppercase tracking-[0.2em] text-kotei-600">
              BONUS: Gobsmacked on the internet
            </p>
            <!-- <h2 class="mt-3 font-display text-3xl font-medium text-kotei-800">
              Public praise and product love
            </h2>
            <p class="mt-4 text-sm leading-7 text-neutral-500">
              A few reactions from people discovering Gobsmacked in the wild.
            </p> -->
            <div class="mt-8 grid gap-4">
              {
                gobsmackedMentions.map((mention) => (
                  <article class="rounded-2xl border border-kotei-200/70 bg-white/80 p-6">
                    <p class="font-display text-xl leading-relaxed text-kotei-800">
                      "{mention.quote}"
                    </p>
                    <div class="mt-5 text-sm text-neutral-500">
                      <span class="font-semibold text-kotei-800">
                        {mention.name}
                      </span>
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
